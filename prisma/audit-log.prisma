model AuditLog {
  id          String      @id @default(uuid())
  actorUserId String?
  entityType  String
  entityId    String?
  action      AuditAction
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  requestId   String?
  createdAt   DateTime    @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
}
