model UserOtp {
  id           String     @id @default(uuid())
  userId       String
  email        String
  purpose      OtpPurpose
  otpCodeHash  String
  expiresAt    DateTime
  verifiedAt   DateTime?
  usedAt       DateTime?
  attemptCount Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
