model Category {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contentItems ContentCategory[]

  @@index([isActive])
  @@index([displayOrder])
}