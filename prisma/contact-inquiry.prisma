model ContactInquiry {
  id            String          @id @default(uuid())
  name          String
  email         String
  phone         String?
  company       String?
  jobTitle      String?
  country       String?
  subject       String?
  message       String
  inquiryType   InquiryType
  source        String?
  status        InquiryStatus   @default(NEW)
  priority      InquiryPriority @default(NORMAL)
  assignedToId  String?
  relatedUserId String?
  tags          Json?
  adminNotes    String?
  respondedAt   DateTime?
  closedAt      DateTime?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  assignedTo  User?             @relation("InquiryAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  relatedUser User?             @relation("InquiryRelatedUser", fields: [relatedUserId], references: [id], onDelete: SetNull)
  activities  InquiryActivity[]

  @@index([status, createdAt])
  @@index([assignedToId])
  @@index([inquiryType])
}
