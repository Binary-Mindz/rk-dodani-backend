model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String
  expiresAt   DateTime
  usedAt      DateTime?
  requestedIp String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
