model UserContentProgress {
  id                 String                @id @default(uuid())
  userId             String
  contentItemId      String
  status             ContentProgressStatus @default(NOT_STARTED)
  progressPercentage Float                 @default(0.0)
  totalTimeSpentSec  Int                   @default(0)
  lastAccessedAt     DateTime              @default(now())
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([userId, contentItemId])
  @@index([userId])
  @@index([contentItemId])
  @@index([status])
}

model UserActivityLog {
  id            String             @id @default(uuid())
  userId        String
  contentItemId String?
  actionType    ActivityActionType
  durationSec   Int                @default(0)
  metadata      Json?
  createdAt     DateTime           @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contentItemId])
  @@index([actionType])
  @@index([createdAt])
}

enum ContentProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ActivityActionType {
  VIEWED
  WATCHED
  DOWNLOADED
  LIKED
  SHARED
}

model TeamInvitation {
  id          String           @id @default(uuid())
  email       String
  role        TeamRole         @default(MEMBER)
  token       String           @unique
  message     String?
  status      InvitationStatus @default(PENDING)
  invitedById String
  createdAt   DateTime         @default(now())
  expiresAt   DateTime

  invitedBy User @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([invitedById])
  @@index([token])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum TeamRole {
  ADMIN
  MEMBER
}

model ContentRating {
  id            String   @id @default(uuid())
  userId        String
  contentItemId String
  rating        Int // 1 to 5 stars
  review        String? // Optional text review comment
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([userId, contentItemId])
  @@index([contentItemId])
}

model TeamJoinRequest {
  id           String        @id @default(uuid())
  userId       String
  parentUserId String
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User @relation("UserJoinRequests", fields: [userId], references: [id], onDelete: Cascade)
  parentUser User @relation("AdminJoinRequests", fields: [parentUserId], references: [id], onDelete: Cascade)

  @@unique([userId, parentUserId])
  @@index([parentUserId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Alert system --- only for admin
enum AlertType {
  INFO
  SUCCESS
  WARNING
  ERROR
  SYSTEM
  MAINTENANCE
}

enum AlertMethod {
  PUSH
  EMAIL
  SMS
}

model Alert {
  id          String      @id @default(uuid())
  alertType   AlertType   @default(INFO)
  message     String
  alertMethod AlertMethod @default(PUSH)
  isEdited    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model SystemMaintenance {
  id                 String   @id @default(uuid())
  isUnderMaintenance Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
